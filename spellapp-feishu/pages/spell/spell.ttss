.container {
  padding: 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}
.ready-section {
  text-align: center;
  padding-top: 100rpx;
}
.stats-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 60rpx;
  margin-bottom: 40rpx;
}
.stats-number {
  font-size: 120rpx;
  font-weight: bold;
  color: #07c160;
}
.stats-label {
  font-size: 28rpx;
  color: #666;
}
.start-btn {
  background: #07c160;
  color: #fff;
  width: 400rpx;
  border-radius: 50rpx;
  font-size: 36rpx;
}
.empty-state {
  padding: 60rpx;
  color: #999;
  font-size: 32rpx;
}
.practice-section {
  max-width: 700rpx;
  margin: 0 auto;
}
.prompt-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 50rpx;
  text-align: center;
  margin-bottom: 40rpx;
}
.example-eng {
  font-size: 34rpx;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.6;
}
.example-chn {
  font-size: 30rpx;
  color: #666;
  display: block;
  margin-bottom: 20rpx;
}
/* 释义分行展示 */
.meaning-row {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding: 8rpx 0;
}
.meaning-pos {
  background: #1890ff;
  color: #fff;
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 16rpx;
  min-width: 60rpx;
}
.meaning-def {
  font-size: 32rpx;
  color: #333;
  line-height: 1.5;
  text-align: left;
}
/* 兼容旧数据 */
.meaning {
  font-size: 40rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 16rpx;
}
.word-tags {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.tag.ielts {
  background: #e6f7ff;
  color: #1890ff;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}
.phonetic {
  font-size: 32rpx;
  color: #666;
}
.play-audio {
  color: #07c160;
  font-size: 28rpx;
  padding: 16rpx 30rpx;
  display: inline-block;
  background: #e8f5e9;
  border-radius: 30rpx;
}
.spell-input {
  background: #fff;
  border: 4rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 30rpx;
  font-size: 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
}
.spell-input.correct {
  border-color: #07c160;
  background: #e8f5e9;
}
.spell-input.wrong {
  border-color: #ff4d4f;
  background: #fff2f0;
}
.feedback {
  margin-bottom: 30rpx;
  text-align: center;
}
.feedback-correct {
  color: #07c160;
  font-size: 36rpx;
  font-weight: bold;
}
.feedback-wrong {
  color: #ff4d4f;
}
.feedback-wrong text {
  display: block;
  font-size: 32rpx;
}
.error-analysis {
  background: #fff2f0;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-top: 20rpx;
}
.error-type {
  color: #ff4d4f;
  font-size: 28rpx;
  font-weight: bold;
}
.error-tip {
  color: #666;
  font-size: 24rpx;
  margin-top: 10rpx;
}
.submit-btn, .next-btn {
  background: #07c160;
  color: #fff;
  width: 300rpx;
  border-radius: 45rpx;
  font-size: 34rpx;
}